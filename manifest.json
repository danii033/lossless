{
  "manifest_version": 3,
  "name": "Lossless",
  "version": "0.2.0",
  "description": "Share tracks to Lossless.",
  "key": "wXqzeGi7iTQZVd81egDAS9sikt3n1iFIKF0MHokRA08=",
  "action": {
    "default_title": "Lossless",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://music.apple.com/*",
    "https://music.youtube.com/*",
    "https://firestore.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://www.youtube.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "login.html",
        "login.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}